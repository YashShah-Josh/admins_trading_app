<h1>Transactions</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th>ID</th>
      <th>User</th>
      <th>Stock</th>
      <th>Type</th>
      <th>Amount</th>
      <th>Brokerage</th>
      <th>Taxes</th>
      <th>Total</th>
      <th>Date</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @transactions.each do |transaction| %>
      <tr>
        <td><%= transaction.id %></td>
        <td><%= transaction.user.name %></td>
        <td><%= transaction.order.stock.company_name %></td>
        <td><%= transaction.transaction_type %></td>
        <td>₹<%= transaction.amount %></td>
        <td>₹<%= transaction.brokerage %></td>
        <td>₹<%= transaction.taxes %></td>
        <td>₹<%= (transaction.amount + transaction.brokerage + transaction.taxes) %></td>
        <td><%= transaction.transaction_date.strftime("%d %b %Y") %></td>
        <td>
          <a href="<%= admins_transaction_path(transaction) %>" class="btn btn-sm btn-primary">View</a>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
