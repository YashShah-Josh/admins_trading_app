<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_importmap_tags %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    /* Custom styles */
    .card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border-radius: 10px;
      border: none;
    }
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
    .stats-card {
      height: 100%;
      border-left: 5px solid rgba(255,255,255,0.5);
    }
    .navbar-brand {
      font-weight: bold;
      padding-left: 1rem;
    }
    .display-6 {
      font-weight: 600;
      font-size: 2.5rem;
    }
    .table {
      border-radius: 8px;
      overflow: hidden;
    }
    .table thead th {
      background-color: #f8f9fa;
      border-bottom: 2px solid #dee2e6;
    }
    .table-hover tbody tr:hover {
      background-color: rgba(0,0,0,0.02);
    }
    .section-title {
      border-left: 4px solid #3461ff;
      padding-left: 10px;
      font-weight: 600;
    }
    .status-badge {
      padding: 6px 10px;
      border-radius: 30px;
      font-size: 12px;
      font-weight: 600;
    }
    .nav-item {
      margin: 0 5px;
    }
    .navbar-nav {
      margin-left: auto;
      padding-right: 1rem;
    }
    .nav-link {
      font-weight: 500;
    }
    .nav-link:hover {
      color: #fff !important;
    }
    .dashboard-title {
      font-weight: 700;
    }
    body {
      background-color: #f5f7fa;
    }
    .page-container {
      min-height: calc(100vh - 56px - 56px);
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand" href="<%= authenticated_admin_root_path %>">FinanceVista Admin Panel</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="<%= authenticated_admin_root_path %>">
              <i class="bi bi-speedometer2 me-1"></i> Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="<%= admins_stocks_path %>">
              <i class="bi bi-graph-up me-1"></i> Stocks
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="<%= admins_transactions_path %>">
              <i class="bi bi-currency-exchange me-1"></i> Transactions
            </a>
          </li>
          <%= link_to destroy_admin_session_path, method: :delete, class: "btn btn-danger btn-sm", 
    id: "logout-button", data: { confirm: "Are you sure?" } do %>
  <i class="bi bi-box-arrow-right me-1"></i> Logout
<% end %>

        
        
        
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4 page-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="d-none d-md-block"></div>
      <div>
      </div>
    </div>
    
    <%= yield %>
  </div>

  <footer class="bg-dark text-white text-center py-3 mt-4">
    <p class="mb-0">© <%= Time.now.year %> FinanceVista Trading Platform Admin Panel</p>
  </footer>

  

  <script>
  document.addEventListener("turbo:load", function() {
    const logoutButton = document.getElementById("logout-button");
    if (!logoutButton) return;
  
    logoutButton.addEventListener("click", function(event) {
      event.preventDefault();
  
      fetch("<%= destroy_admin_session_path %>", {
        method: "DELETE",
        headers: {
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content,
          "Accept": "text/html"
        }
      }).then(() => {
        window.location.href = "<%= new_admin_session_path %>"; // Redirect to login
      }).catch(error => console.error("Logout failed:", error));
    });
  });
  </script>
  
</body>
</html>