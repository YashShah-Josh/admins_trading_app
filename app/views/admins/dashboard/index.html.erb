<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">
  <div class="col-md-3">
    <div class="card bg-primary text-white shadow">
      <div class="card-body">
        <h5>Total Users</h5>
        <p class="display-6"><%= @total_users %></p>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card bg-success text-white shadow">
      <div class="card-body">
        <h5>Total Orders</h5>
        <p class="display-6"><%= @total_orders %></p>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card bg-warning text-white shadow">
      <div class="card-body">
        <h5>Total Transactions</h5>
        <p class="display-6"><%= @total_transactions %></p>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card bg-danger text-white shadow">
      <div class="card-body">
        <h5>Total Stocks</h5>
        <p class="display-6"><%= @total_stocks %></p>
      </div>
    </div>
  </div>
</div>

<!-- Revenue, Brokerage, and Taxes -->
<div class="row mt-4">
  <div class="col-md-4">
    <div class="card bg-success text-white shadow">
      <div class="card-body">
        <h5 class="card-title">Total Revenue</h5>
        <p class="display-6">₹<%= @total_revenue %></p>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card bg-info text-white shadow">
      <div class="card-body">
        <h5 class="card-title">Total Profit</h5>
        <p class="display-6">₹<%= @total_brokerage %></p>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card bg-danger text-white shadow">
      <div class="card-body">
        <h5 class="card-title">Total Taxes</h5>
        <p class="display-6">₹<%= @total_taxes %></p>
      </div>
    </div>
  </div>
</div>

<!-- Recent Orders -->
<h3 class="mt-5">Recent Orders</h3>
<table class="table table-striped">
  <thead>
    <tr>
      <th>ID</th>
      <th>Stock</th>
      <th>Price</th>
      <th>Quantity</th>
      <th>Status</th>
      <th>Created At</th>
    </tr>
  </thead>
  <tbody>
    <% @latest_orders.each do |order| %>
      <tr>
        <td><%= order.id %></td>
        <td><%= order.stock_id %></td>
        <td><%= order.price %></td>
        <td><%= order.quantity %></td>
        <td><%= order.status %></td>
        <td><%= order.created_at.strftime("%d-%m-%Y %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<!-- Recent Transactions -->
<h3 class="mt-5">Recent Transactions</h3>
<table class="table table-striped">
  <thead>
    <tr>
      <th>ID</th>
      <th>Order ID</th>
      <th>Amount</th>
      <th>Transaction Type</th>
      <th>Date</th>
    </tr>
  </thead>
  <tbody>
    <% @latest_transactions.each do |txn| %>
      <tr>
        <td><%= txn.id %></td>
        <td><%= txn.order_id %></td>
        <td><%= txn.amount %></td>
        <td><%= txn.transaction_type %></td>
        <td><%= txn.transaction_date.strftime("%d-%m-%Y %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

